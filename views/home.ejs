<%- include('partials/head') %>
    </head>

    <body>

        <%- include('partials/nav') %>
            <!-- ⭐ Centered Welcome Card -->
            <div class="flex items-center justify-center mt-20 px-4">
                <div class="bg-white px-10 py-8 rounded-xl shadow-lg">
                    <h1 class="text-3xl font-bold text-gray-800">
                        Here are our registered home:
                    </h1>

                    <ul class="space-y-2 mt-4">
                        <% registerHome.forEach(home=> { %>
                            <li class="bg-white border border-gray-200 rounded-lg px-4 py-2 shadow-sm 
                   hover:bg-gray-50 hover:shadow-md transition-all cursor-pointer">
                                <%= home.houseName %>
                            </li>
                            <% }) %>
                    </ul>
                </div>
            </div>




    </body>

    </html>